# Server Configuration
PORT=3000
APP_URL=http://localhost:3000

# Database
# SQLite database is used by default - no configuration needed

# Email Configuration (Optional)
# If not provided, the app will log emails to the console
# For production, configure your SMTP settings:

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# From Email Address
FROM_EMAIL=noreply@example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Development Email Service (Optional)
# For testing with ethereal.email
# ETHEREAL_USER=your-ethereal-user
# ETHEREAL_PASS=your-ethereal-password
